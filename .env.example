# ALFAJOR - Variables de entorno
# Copiar a .env y configurar

FLASK_APP=alfajor
FLASK_ENV=development

# Obligatorio en producción
SECRET_KEY=change-me-in-production-use-random-string

# Base de datos
# PostgreSQL (producción)
DATABASE_URL=postgresql://user:password@localhost:5432/alfajor
# SQLite (desarrollo)
# DATABASE_URL=sqlite:///alfajor.db
